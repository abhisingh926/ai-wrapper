# ── App ──
DEBUG=false
APP_NAME=AI Wrapper Platform

# ── Database ──
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_DB_PASSWORD@localhost:5432/ai_wrapper

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── Auth (IMPORTANT: Generate a strong random key!) ──
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_GENERATE_A_STRONG_KEY
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Frontend URL ──
FRONTEND_URL=http://localhost:3000

# ── Email (Resend) ──
RESEND_API_KEY=
FROM_EMAIL=noreply@yourdomain.com

# ── Stripe ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_BUSINESS_MONTHLY=

# ── Encryption (IMPORTANT: Generate a Fernet key!) ──
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=CHANGE_ME_GENERATE_A_FERNET_KEY

# ── OAuth ──
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_URI=http://localhost:3000/auth/callback

# ── OpenAI (fallback, admin panel keys take priority) ──
OPENAI_API_KEY=
